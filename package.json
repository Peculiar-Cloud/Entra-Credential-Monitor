{
  "name": "entra-credential-monitor",
  "version": "2.1.0",
  "description": "Monitor Microsoft Entra ID app and service-principal credentials for upcoming expiration",
  "type": "module",
  "main": "dist/run.js",
  "license": "MIT",
  "homepage": "https://github.com/Peculiar-Cloud/Entra-Credential-Monitor#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Peculiar-Cloud/Entra-Credential-Monitor.git"
  },
  "bugs": {
    "url": "https://github.com/Peculiar-Cloud/Entra-Credential-Monitor/issues"
  },
  "keywords": [
    "entra-id",
    "azure-ad",
    "microsoft-graph",
    "credential-rotation",
    "app-registrations",
    "service-principals",
    "security-monitoring"
  ],
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "build": "tsc",
    "start": "node dist/run.js",
    "dev": "tsx src/run.ts",
    "monitor": "node dist/run.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "format:check": "biome format",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "update": "pnpm update --interactive --latest"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@azure/identity": "^4.13.1",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "pino": "^10.3.1",
    "resend": "^6.16.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.9",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
