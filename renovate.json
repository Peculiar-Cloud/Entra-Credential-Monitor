{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": true,
  "labels": ["dependencies"],
  "minimumReleaseAge": "25 hours",
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "packageRules": [
    {
      "description": "Group and automerge low-risk npm patch, pin, and digest updates after CI passes.",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["patch", "pin", "digest"],
      "groupName": "npm patch updates",
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Group npm minor updates for review.",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor"],
      "groupName": "npm minor updates"
    },
    {
      "description": "Group and automerge GitHub Actions patch, pin, and digest updates after CI passes.",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["patch", "pin", "digest"],
      "groupName": "github-actions patch updates",
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Group GitHub Actions minor updates for review.",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor"],
      "groupName": "github-actions minor updates"
    },
    {
      "description": "Group and automerge Docker digest, pin, and patch updates after CI passes.",
      "matchManagers": ["dockerfile"],
      "matchUpdateTypes": ["patch", "pin", "digest"],
      "groupName": "container patch updates",
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Group Docker minor updates for review.",
      "matchManagers": ["dockerfile"],
      "matchUpdateTypes": ["minor"],
      "groupName": "container minor updates"
    },
    {
      "description": "Require dashboard approval before major updates.",
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true
    }
  ]
}
