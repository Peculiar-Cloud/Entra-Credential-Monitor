# ===================================================================
# Entra ID App Registration Monitor - environment variables
# ===================================================================
# This file documents every variable the app reads. Copy it to .env.local for
# local runs, then fill in your own values. Do not commit .env.local.
# ===================================================================

# ----- Microsoft Entra ID -----------------------------------------
# Option 1: multiple tenants as a JSON array (takes precedence).
# ENTRA_TENANTS='[{"tenantId":"00000000-0000-0000-0000-000000000000","clientId":"11111111-1111-1111-1111-111111111111","clientSecret":"your-client-secret","name":"Example Tenant"}]'

# Option 2: a single tenant via individual variables.
ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_ID=11111111-1111-1111-1111-111111111111
ENTRA_CLIENT_SECRET=your-client-secret
ENTRA_TENANT_NAME=My Organization

# ----- Email delivery (Resend) ------------------------------------
RESEND_API_KEY=re_your_api_key
# From-address; must be on a Resend-verified domain. Also receives error alerts.
SENDER_EMAIL=security@yourdomain.com
# Comma-separated report recipients.
EMAIL_RECIPIENTS=admin@yourdomain.com,security@yourdomain.com
# Optional technical contact (email) used in self-monitoring alerts.
# TECHNICAL_CONTACT=admin@yourdomain.com

# ----- Monitoring configuration -----------------------------------
# Days before expiration to warn (default 30).
WARNING_DAYS=30
# Days before the monitor's own credentials expire to warn (default 60).
SELF_MONITORING_WARNING_DAYS=60
# Send a report even when no issues are found (default false).
ALWAYS_SEND_REPORT=false
# Credentials expired longer than this many days are collapsed into a compact
# reference table in the report instead of listed in full (default 90).
EXPIRED_GRACE_DAYS=90

# ----- Healthchecks.io (optional) ---------------------------------
# Cron-monitoring ping target; accepts a bare UUID or a full URL.
# HEALTHCHECKS_PING_URL=https://hc-ping.com/your-uuid-here
